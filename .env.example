# =====================================================
# AI Job Search Assistant — Environment Configuration
# =====================================================
# Copy this file to .env and fill in your API keys
# cp .env.example .env

# ─── AI Engine (REQUIRED) ──────────────────────────
# Get your key: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to use (recommended: claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── Job Search Providers (at least ONE required) ───
# SerpAPI — https://serpapi.com (100 free searches/month)
SERPAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tavily — https://tavily.com (1000 free searches/month)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Server ─────────────────────────────────────────
PORT=3031
NODE_ENV=development

# ─── Frontend ───────────────────────────────────────
VITE_API_URL=http://localhost:${PORT}/api

# ─── Database ───────────────────────────────────────
DB_PATH=./data/jobsearch.db

# ─── Automation ─────────────────────────────────────
# Default auto-search interval in hours (0 = disabled)
AUTO_SEARCH_INTERVAL=0
